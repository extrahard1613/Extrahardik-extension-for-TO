{
  "manifest_version": 3,
  "name": "Extrahardik extension for TO",
  "version": "1.0.0",
  "content_scripts": [
    {
      "matches": [
        "*://*.tankionline.com/*"
      ],
      "js": [
        "injector.js"
      ],
      "css": [
        "style.css"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "*://*.tankionline.com/*"
      ],
      "resources": [
        "main.js",
        "helpers.js",

        "multipleAccount/constants.js",
        "multipleAccount/accountService.js",
        "multipleAccount/index.js",
        "multipleAccount/menu.js",
        "multipleAccount/observers.js",
        "multipleAccount/premium.js",
        "multipleAccount/storage.js",
        "multipleAccount/tabs.js",
        "multipleAccount/ui.js",

        "images/switchAccountsButton.png",
        "images/closeAccountListButton.png"
      ]
    }
  ]
}